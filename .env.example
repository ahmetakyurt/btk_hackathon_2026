# ─────────────────────────────────────────────────────────────
#  OptiPrice AI — environment configuration template
#  Copy to `.env` and fill values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- Backend Core API (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./optiprice.db
LOG_LEVEL=INFO

# --- Mock Platform Services ---
MOCK_TRENDYOL_URL=http://localhost:9001
MOCK_AMAZON_URL=http://localhost:9002
MOCK_OWN_SITE_URL=http://localhost:9003

# --- Mock service own DBs ---
MOCK_TRENDYOL_DB=sqlite+aiosqlite:///./mock_trendyol.db
MOCK_AMAZON_DB=sqlite+aiosqlite:///./mock_amazon.db
MOCK_OWN_SITE_DB=sqlite+aiosqlite:///./mock_own_site.db

# --- Pricing Agent ---
COMPETITOR_POLL_INTERVAL_SECONDS=5
GEMINI_TIMEOUT_SECONDS=15
PRICING_AGENT_MIN_MARGIN=0.05

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
#  OptiPrice AI — environment configuration template
#  Copy to `.env` (root) and fill values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Shared secret (Docker Compose reads this for AUTH_SECRET) ──
AUTH_SECRET=change-me-to-a-32-plus-char-random-string

# ─────────────────────────────────────────────────────────────
#  backend/.env  (copy separately to backend/.env)
# ─────────────────────────────────────────────────────────────

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Database (Supabase Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# Auth (must match AUTH_SECRET above)
NEXTAUTH_SECRET=change-me-to-a-32-plus-char-random-string

# Password reset
PASSWORD_RESET_TTL_SECONDS=3600

# Email (Resend)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
APP_PUBLIC_URL=http://localhost:3000

# Mock service URLs (Docker Compose overrides these automatically)
MOCK_TRENDYOL_URL=http://localhost:9001
MOCK_AMAZON_URL=http://localhost:9002
MOCK_OWN_SITE_URL=http://localhost:9003

# Pricing
COMPETITOR_POLL_INTERVAL_SECONDS=5
GEMINI_TIMEOUT_SECONDS=15
PRICING_AGENT_MIN_MARGIN=0.05

# ─────────────────────────────────────────────────────────────
#  frontend/.env.local  (copy separately)
# ─────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-32-plus-char-random-string
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
